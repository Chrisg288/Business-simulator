{
  "template_id": "PassengerVehicleOffer",
  "class_id": "PassengerVehicleOffer",
  "inherits_from": "BaseOffer",
  "presentation_type": "datagrid",
  "fields": [
    {
      "name": "offer_id",
      "type": "text",
      "required": true,
      "grid": true
    },
    {
      "name": "title",
      "type": "text",
      "required": true,
      "grid": true
    },
    {
      "name": "provider",
      "type": "entity_ref",
      "required": false,
      "grid": true
    },
    {
      "name": "price",
      "type": "currency",
      "required": false,
      "grid": true
    },
    {
      "name": "availability",
      "type": "enum",
      "values": [
        "available",
        "limited",
        "watch",
        "expired",
        "unknown"
      ],
      "grid": true
    },
    {
      "name": "location",
      "type": "text",
      "required": false,
      "grid": true
    },
    {
      "name": "evidence_status",
      "type": "enum",
      "values": [
        "none",
        "claimed",
        "linked",
        "verified"
      ],
      "grid": true
    },
    {
      "name": "risk",
      "type": "enum",
      "values": [
        "low",
        "medium",
        "high",
        "unknown"
      ],
      "grid": true
    },
    {
      "name": "cvu_score",
      "type": "number",
      "required": false,
      "grid": true
    },
    {
      "name": "year",
      "type": "integer",
      "grid": true
    },
    {
      "name": "make",
      "type": "text",
      "grid": true
    },
    {
      "name": "model",
      "type": "text",
      "grid": true
    },
    {
      "name": "odometer_km",
      "type": "number",
      "unit": "km",
      "grid": true
    },
    {
      "name": "body_style",
      "type": "enum",
      "values": [
        "car",
        "van",
        "truck",
        "suv",
        "wagon",
        "unknown"
      ],
      "grid": true
    },
    {
      "name": "fuel_type",
      "type": "enum",
      "values": [
        "gas",
        "diesel",
        "hybrid",
        "electric",
        "unknown"
      ],
      "grid": true
    },
    {
      "name": "inspection_status",
      "type": "enum",
      "values": [
        "none",
        "claimed",
        "recent",
        "mechanic_verified"
      ],
      "grid": true
    },
    {
      "name": "repair_estimate",
      "type": "currency",
      "unit": "CAD",
      "grid": false
    }
  ],
  "default_grid_columns": [
    "offer_id",
    "title",
    "provider",
    "price",
    "availability",
    "location",
    "evidence_status",
    "risk",
    "cvu_score",
    "year",
    "make",
    "model",
    "odometer_km",
    "body_style",
    "fuel_type",
    "inspection_status"
  ],
  "comparison_factors": [
    "need_fit",
    "availability",
    "comparative_cost",
    "comparative_quality",
    "time_value",
    "risk_value",
    "system_value",
    "evidence_strength"
  ]
}